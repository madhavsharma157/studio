{
	"info": {
		"_postman_id": "geocampus-manager-id",
		"name": "GeoCampus Manager",
		"description": "Collection for testing school management and geospatial endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Add School",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Example School\",\n    \"address\": \"456 Learning Way\",\n    \"latitude\": 19.1200,\n    \"longitude\": 72.9000\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/addSchool",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"addSchool"
					]
				}
			},
			"response": []
		},
		{
			"name": "List Nearby Schools",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/listSchools?latitude=19.0760&longitude=72.8777",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"listSchools"
					],
					"query": [
						{
							"key": "latitude",
							"value": "19.0760"
						},
						{
							"key": "longitude",
							"value": "72.8777"
						}
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:9002",
			"type": "string"
		}
	]
}
